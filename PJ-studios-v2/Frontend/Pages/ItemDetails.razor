@page "/item/{ItemId}"
@using System.Net.Http.Json
@using Frontend.Services
@inject HttpClient Http
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject Microsoft.JSInterop.IJSRuntime JSRuntime

<PageTitle>Item detaljer</PageTitle>

@if (_isLoading)
{
    <p><em>Loader item...</em></p>
}
else if (_item == null)
{
    <div class="alert alert-danger" role="alert">Item ikke fundet.</div>
    <a href="/items" class="btn btn-secondary">Tilbage til items</a>
}
else
{
    <div class="mb-3">
        <a href="/items" class="btn btn-secondary btn-sm">← Tilbage</a>
    </div>

    <div class="row">
        <div class="col-md-6">
            @if (!string.IsNullOrWhiteSpace(_item.ImageUrl))
            {
                <img src="@_item.ImageUrl" alt="@_item.Name" style="max-width: 100%; border-radius: 8px; margin-bottom: 20px;" />
            }
        </div>
        <div class="col-md-6">
            <h1>@_item.Name</h1>
            <p class="text-muted">@_item.Description</p>

            @if (_canEditItem)
            {
                <div class="d-flex gap-2 mb-3">
                    <button class="btn btn-outline-primary btn-sm" @onclick="ToggleEditMode">
                        @(_isEditing ? "Annuller" : "Rediger")
                    </button>
                    <button class="btn btn-outline-danger btn-sm" @onclick="DeleteItemAsync" disabled="@_isDeletingItem">
                        @(_isDeletingItem ? "Sletter..." : "Slet")
                    </button>
                </div>
            }

            @if (_isEditing)
            {
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Rediger item</h5>
                        <div class="mb-3">
                            <label class="form-label" for="editName">Navn</label>
                            <input id="editName" class="form-control" @bind="_editName" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="editDescription">Beskrivelse</label>
                            <textarea id="editDescription" class="form-control" rows="4" @bind="_editDescription"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="editImageUrl">Billede URL</label>
                            <input id="editImageUrl" class="form-control" @bind="_editImageUrl" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="editImageFile">Eller vælg en billedfil</label>
                            <InputFile id="editImageFile" class="form-control" OnChange="OnEditFileSelectedAsync" accept="image/*" />
                            <div class="form-text">Understøtter billeder op til 2 MB.</div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_editImageUrl))
                        {
                            <div class="mb-3">
                                <img src="@_editImageUrl" alt="Forhaandsvisning" style="max-width: 220px; max-height: 220px; border-radius: 8px;" />
                            </div>
                        }
                        <button class="btn btn-primary" @onclick="SaveItemAsync" disabled="@_isSavingItem">
                            @(_isSavingItem ? "Gemmer..." : "Gem ændringer")
                        </button>
                    </div>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="alert alert-danger" role="alert">@_errorMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(_successMessage))
            {
                <div class="alert alert-success" role="alert">@_successMessage</div>
            }

            <div class="card mt-4">
                <div class="card-body">
                    <h5 class="card-title">@(_hasExistingRating ? "Opdater din rating" : "Sæt din rating")</h5>
                    <div class="mb-3">
                        <label class="form-label" for="ratingScore">Score (1.0-10.0)</label>
                        <input id="ratingScore" type="number" class="form-control" min="1" max="10" step="0.1" @bind="_ratingScore" />
                        <div class="text-center mt-2">
                            <span style="font-size: 24px; font-weight: bold;">@_ratingScore.ToString("0.0")</span> / 10
                        </div>
                    </div>
                    <button class="btn btn-primary w-100" @onclick="SubmitRatingAsync" disabled="@_isSubmittingRating">
                        @(_isSubmittingRating ? "Gemmer rating..." : _hasExistingRating ? "Opdater rating" : "Gem rating")
                    </button>
                </div>
            </div>

            @if (_allRatings.Count > 0)
            {
                <div class="card mt-4">
                    <div class="card-body">
                        <h5 class="card-title">Alle ratings</h5>
                        <p class="text-muted">Gennemsnitlig score: <strong>@_allRatings.Average(r => r.Score).ToString("0.0")</strong> / 10</p>
                        <div class="list-group list-group-sm">
                            @foreach (var rating in _allRatings.OrderByDescending(r => r.Id))
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center gap-3">
                                        <div>
                                            <div class="fw-semibold">@rating.Username</div>
                                        </div>
                                        <span class="badge bg-secondary">@rating.Score.ToString("0.0")</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public string ItemId { get; set; } = string.Empty;

    private bool _hasExistingRating;
    private ItemDto? _item;
    private decimal _ratingScore = 5.0m;
    private bool _isLoading = true;
    private bool _isSubmittingRating;
    private bool _isEditing;
    private bool _isSavingItem;
    private bool _isDeletingItem;
    private string _currentUserId = string.Empty;
    private string _editName = string.Empty;
    private string _editDescription = string.Empty;
    private string _editImageUrl = string.Empty;
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;
    private List<RatingDto> _allRatings = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadItemAsync();
    }

    private async Task LoadItemAsync()
    {
        _isLoading = true;
        _errorMessage = string.Empty;
        _successMessage = string.Empty;
        _allRatings = new List<RatingDto>();
        _hasExistingRating = false;
        _ratingScore = 5.0m;

        try
        {
            _item = await Http.GetFromJsonAsync<ItemDto>($"/api/item/{ItemId}");
            _currentUserId = await AuthService.GetUserIdAsync() ?? string.Empty;

            if (_item != null)
            {
                var response = await Http.GetAsync($"/api/ratings/item/{ItemId}");
                if (response.IsSuccessStatusCode)
                {
                    _allRatings = await response.Content.ReadFromJsonAsync<List<RatingDto>>() ?? new List<RatingDto>();
                }

                var userId = await AuthService.GetUserIdAsync();
                if (!string.IsNullOrWhiteSpace(userId))
                {
                    var existingRating = _allRatings.FirstOrDefault(r => r.UserId == userId);
                    _hasExistingRating = existingRating != null;
                    if (existingRating != null)
                    {
                        _ratingScore = existingRating.Score;
                    }
                }

                if (_isEditing)
                {
                    _editName = _item.Name;
                    _editDescription = _item.Description;
                    _editImageUrl = _item.ImageUrl;
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Kunne ikke hente item: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SubmitRatingAsync()
    {
        _errorMessage = string.Empty;
        _successMessage = string.Empty;

        var userId = await AuthService.GetUserIdAsync();
        if (string.IsNullOrWhiteSpace(userId))
        {
            _errorMessage = "Du skal være logget ind for at give en rating.";
            return;
        }

        _isSubmittingRating = true;
        try
        {
            var request = new CreateRatingRequest
            {
                ItemId = ItemId,
                UserId = userId,
                Score = _ratingScore
            };

            var response = await Http.PostAsJsonAsync("/api/ratings", request);
            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = $"Kunne ikke gemme rating: {(int)response.StatusCode}";
                return;
            }

            _successMessage = "Rating gemt!";
            await LoadItemAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fejl: {ex.Message}";
        }
        finally
        {
            _isSubmittingRating = false;
        }
    }

    private bool _canEditItem => _item != null && !string.IsNullOrWhiteSpace(_currentUserId) && string.Equals(_item.UserId, _currentUserId, StringComparison.Ordinal);

    private void ToggleEditMode()
    {
        if (!_canEditItem)
        {
            return;
        }

        _isEditing = !_isEditing;
        _errorMessage = string.Empty;
        _successMessage = string.Empty;

        if (_isEditing && _item != null)
        {
            _editName = _item.Name;
            _editDescription = _item.Description;
            _editImageUrl = _item.ImageUrl;
        }
    }

    private async Task SaveItemAsync()
    {
        if (_item == null)
        {
            return;
        }

        var token = await AuthService.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token))
        {
            _errorMessage = "Du skal være logget ind for at redigere et item.";
            return;
        }

        _errorMessage = string.Empty;
        _successMessage = string.Empty;
        _isSavingItem = true;

        try
        {
            var request = new HttpRequestMessage(HttpMethod.Put, $"/api/item/{ItemId}")
            {
                Content = JsonContent.Create(new UpdateItemRequest
                {
                    Name = _editName.Trim(),
                    Description = _editDescription.Trim(),
                    ImageUrl = _editImageUrl.Trim()
                })
            };

            await AuthService.ApplyAuthorizationHeaderAsync(request);

            var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = $"Kunne ikke gemme ændringer: {(int)response.StatusCode} {response.StatusCode}";
                return;
            }

            _successMessage = "Item opdateret.";
            _isEditing = false;
            await LoadItemAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fejl: {ex.Message}";
        }
        finally
        {
            _isSavingItem = false;
        }
    }

    private async Task OnEditFileSelectedAsync(InputFileChangeEventArgs e)
    {
        _errorMessage = string.Empty;

        var file = e.File;
        if (file == null)
        {
            _editImageUrl = string.Empty;
            return;
        }

        const long maxFileSize = 2 * 1024 * 1024;
        if (file.Size > maxFileSize)
        {
            _editImageUrl = string.Empty;
            _errorMessage = "Billedet er for stort. Maks 2 MB.";
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(maxFileSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);

            var base64 = Convert.ToBase64String(ms.ToArray());
            _editImageUrl = $"data:{file.ContentType};base64,{base64}";
        }
        catch (Exception ex)
        {
            _editImageUrl = string.Empty;
            _errorMessage = $"Kunne ikke læse billedet: {ex.Message}";
        }
    }

    private async Task DeleteItemAsync()
    {
        if (_item == null)
        {
            return;
        }

        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Vil du slette '{_item.Name}'?");
        if (!confirmed)
        {
            return;
        }

        var token = await AuthService.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token))
        {
            _errorMessage = "Du skal være logget ind for at slette et item.";
            return;
        }

        _errorMessage = string.Empty;
        _successMessage = string.Empty;
        _isDeletingItem = true;

        try
        {
            var request = new HttpRequestMessage(HttpMethod.Delete, $"/api/item/{ItemId}");
            await AuthService.ApplyAuthorizationHeaderAsync(request);

            var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = $"Kunne ikke slette item: {(int)response.StatusCode} {response.StatusCode}";
                return;
            }

            NavigationManager.NavigateTo("/items");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fejl: {ex.Message}";
        }
        finally
        {
            _isDeletingItem = false;
        }
    }

    private sealed class ItemDto
    {
        public string Id { get; set; } = string.Empty;
        public string UserId { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string ImageUrl { get; set; } = string.Empty;
    }

    private sealed class UpdateItemRequest
    {
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string ImageUrl { get; set; } = string.Empty;
    }

    private sealed class RatingDto
    {
        public int Id { get; set; }
        public string ItemId { get; set; } = string.Empty;
        public string UserId { get; set; } = string.Empty;
        public string Username { get; set; } = string.Empty;
        public decimal Score { get; set; }
    }

    private sealed class CreateRatingRequest
    {
        public string ItemId { get; set; } = string.Empty;
        public string UserId { get; set; } = string.Empty;
        public decimal Score { get; set; }
    }
}
