@using System.Net.Http.Json
@using Frontend.Services
@inject HttpClient Http
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<nav class="navbar">
    <div class="nav-container">
        <button class="hamburger @(isOpen ? "active" : "")" @onclick="ToggleNavMenu" title="Navigation menu">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <div class="nav-menu @(isOpen ? "active" : "")">
            <NavLink href="" class="nav-link" @onclick="CloseMenu" Match="NavLinkMatch.All">
                Home
            </NavLink>
            <NavLink href="leaderboard" class="nav-link" @onclick="CloseMenu">
                Leaderboard
            </NavLink>
            <NavLink href="items" class="nav-link" @onclick="CloseMenu">
                Items
            </NavLink>
            <NavLink href="users" class="nav-link" @onclick="CloseMenu">
                Brugere
            </NavLink>
        </div>

        <div class="nav-auth">
            @if (isLoggedIn)
            {
                <NavLink href="my-profile" class="nav-link nav-link-profile" @onclick="CloseMenu">
                    Min bruger
                </NavLink>
                <span class="user-greeting">@userDisplay</span>
                <button class="btn-logout" @onclick="Logout">Logout</button>
            }
            else
            {
                <NavLink href="login" class="btn-icon-login" title="Login" aria-label="Login">
                    <span class="icon-login" aria-hidden="true"></span>
                </NavLink>
            }
        </div>
    </div>
</nav>

@code {
    private bool isOpen = false;
    private bool isLoggedIn = false;
    private string userDisplay = string.Empty;
    

    protected override async Task OnInitializedAsync()
    {
        AuthService.AuthStateChanged += HandleAuthStateChanged;
        await CheckAuthStatus();
    }

    public void Dispose()
    {
        AuthService.AuthStateChanged -= HandleAuthStateChanged;
    }

    private async Task CheckAuthStatus()
    {
        var token = await AuthService.GetTokenAsync();
        isLoggedIn = !string.IsNullOrWhiteSpace(token);
        userDisplay = string.Empty;

        if (!isLoggedIn || token == null)
        {
            return;
        }

        try
        {
            var request = new HttpRequestMessage(HttpMethod.Get, "/api/auth/me");
            await AuthService.ApplyAuthorizationHeaderAsync(request);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var profile = await response.Content.ReadFromJsonAsync<UserProfileDto>();
                userDisplay = profile?.Username ?? profile?.Email ?? "Logget ind";
                return;
            }
        }
        catch
        {
            // Fall back to token parsing if the profile endpoint is unavailable.
        }

        userDisplay = ExtractEmailFromJwt(token) ?? "Logget ind";
    }

    private static string? ExtractEmailFromJwt(string token)
    {
        try
        {
            var parts = token.Split('.');
            if (parts.Length != 3)
                return null;

            var payload = parts[1];
            payload = payload.Replace("-", "+").Replace("_", "/");
            payload += new string('=', (4 - payload.Length % 4) % 4);

            var decoded = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(payload));
            using var doc = System.Text.Json.JsonDocument.Parse(decoded);

            if (doc.RootElement.TryGetProperty("email", out var emailElement))
            {
                return emailElement.GetString();
            }

            return null;
        }
        catch
        {
            return null;
        }
    }

    private void ToggleNavMenu()
    {
        isOpen = !isOpen;
    }

    private void CloseMenu()
    {
        isOpen = false;
    }

    private async Task Logout()
    {
        await AuthService.ClearTokenAsync();
        isLoggedIn = false;
        userDisplay = string.Empty;
        CloseMenu();
        NavigationManager.NavigateTo("/");
    }

    private async void HandleAuthStateChanged()
    {
        await CheckAuthStatus();
        await InvokeAsync(StateHasChanged);
    }

    private sealed class UserProfileDto
    {
        public string Id { get; set; } = string.Empty;
        public string Username { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
        public DateTime UpdatedAt { get; set; }
    }
}
